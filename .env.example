# =============================================================================
# Open-Whiteboard — IDE / Developer Environment
# Fill in actual secrets in .env.local.
# =============================================================================

# --- WebSocket Server (local defaults) ---
# The URL the Next.js client uses to connect to the Yjs WebSocket server.
NEXT_PUBLIC_WS_URL=

# The URL the Next.js client uses to connect to the Socket.IO server.
NEXT_PUBLIC_SOCKET_URL=

# Port the ws-server.ts process listens on.
WS_PORT=

# The URL the WebSocket server uses for CORS — should match `next dev` address.
CLIENT_URL=

# --- Room Store (Redis via Upstash) ---
ROOM_STORE_TYPE=redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=